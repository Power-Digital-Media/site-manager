rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ─── Helper Functions ───────────────────────────────────────
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function ownsSite(siteId) {
      return isAuthenticated() && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.siteId == siteId;
    }
    
    function canAccessSite(siteId) {
      return isAdmin() || ownsSite(siteId);
    }
    
    // ─── Site Assets ────────────────────────────────────────────
    // /sites/{siteId}/**
    match /sites/{siteId}/{allPaths=**} {
      // Anyone can read (images are publicly visible on the website)
      allow read: if true;
      // Only site owner or admin can upload/delete
      allow write: if canAccessSite(siteId);
    }
    
    // ─── Upload Validation ──────────────────────────────────────
    // Enforce file size and type constraints
    match /sites/{siteId}/images/{imageId} {
      allow read: if true;
      allow write: if canAccessSite(siteId)
        && request.resource.size < 10 * 1024 * 1024  // Max 10MB
        && request.resource.contentType.matches('image/.*');  // Images only
    }
    
    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
